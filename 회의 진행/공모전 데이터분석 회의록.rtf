\f0\fs24 \cf0 # \uc0\u45936 \u51060 \u53552  \u48516 \u49437  \u44228 \u54925 \
\
0\uc0\u45800 \u44228  \'97 \u50780  \u52397 \u45380 \u51064 \u44032  (\u48176 \u44221 )\
\
\uc0\u48516 \u49437 : \u48712 \u46020 \u48516 \u49437 \u47564  (\u53685 \u44228 \u52397  \u44277 \u44060 \u51088 \u47308  \u54876 \u50857 , \u48324 \u46020  .sav \u48516 \u49437  \u48520 \u54596 \u50836 )\
\uc0\u52397 \u45380  \u44256 \u50857 \u54805 \u53468 \u48324  \u48708 \u50984  \u46321 \u51008  \u48372 \u44256 \u49436  \u51064 \u50857 \u51004 \u47196  \u52649 \u48516 \
\
1\uc0\u45800 \u44228  \'97 \u49892 \u51228  \u50668 \u44032  vs \u55148 \u47581  \u50668 \u44032  \u44201 \u52264  (\u44032 \u49444  1)\
\
\uc0\u45936 \u51060 \u53552 : \u44397 \u48124  \u48120 \u47000 \u51064 \u49885 \'b7\u44032 \u52824 \u44288 \u51312 \u49324 \
\uc0\u54596 \u50836 \u54620  \u48516 \u49437 :\
\
\uc0\u48712 \u46020 \u48516 \u49437  \'97 \u49892 \u51228  \u50668 \u44032 \u54876 \u46041  \u50976 \u54805 \u48324  \u48708 \u50984 , \u55148 \u47581  \u50668 \u44032 \u54876 \u46041  \u50976 \u54805 \u48324  \u48708 \u50984  \u44033 \u44033 \
\uc0\u45824 \u51025 \u54364 \u48376  t-\u44160 \u51221 (paired t-test) \'97 \u47564 \u50557  "\u49892 \u51228  \u50668 \u44032  \u47564 \u51313 \u46020 "\u50752  "\u55148 \u47581  \u50668 \u44032  \u47564 \u51313 \u46020 "\u52376 \u47100  \u44057 \u51008  \u51025 \u45813 \u51088 \u51032  \u46160  \u51216 \u49688 \u47484  \u48708 \u44368 \u54624  \u49688  \u51080 \u45716  \u50672 \u49549 \u54805  \u47928 \u54637 \u51060  \u51080 \u45796 \u47732  \u51201 \u54633 \
\uc0\u44368 \u52264 \u48516 \u49437  \'97 \u49892 \u51228  \u50668 \u44032 \u50976 \u54805 (\u48276 \u51452 ) \'d7 \u55148 \u47581  \u50668 \u44032 \u50976 \u54805 (\u48276 \u51452 )\u51012  \u44368 \u52264 \u54364 \u47196  \'97 "\u49892 \u51228 \u45716  \u49548 \u44537 \u51201 \u51064 \u45936  \u55148 \u47581 \u51008  \u51201 \u44537 \u51201 "\u51060 \u46972 \u45716  \u54056 \u53556 \u51012  \u51649 \u51217  \u48372 \u50668 \u51468  (\u51060 \u44172  \u44032 \u51109  \u51649 \u44288 \u51201 \u51060 \u44256  \u49884 \u44033 \u54868 \u54616 \u44592  \u51339 \u51020 )\
\
\
\uc0\u54924 \u44480 \u48516 \u49437  \u48520 \u54596 \u50836 : \u51060  \u45800 \u44228 \u45716  "\u52264 \u51060 \u44032  \u51080 \u45796 /\u50630 \u45796 "\u47484  \u48372 \u50668 \u51452 \u45716  \u44172  \u47785 \u51201 \u51060 \u46972  \u48516 \u54252 \'b7\u44368 \u52264 \u54364  \u49688 \u51456 \u50640 \u49436  \u52649 \u48516 \
\

\fs36 2\uc0\u45800 \u44228  (\u49888 \u44508  \u54645 \u49900 ) \'97 \u44201 \u52264 \u44032  \u49548 \u46301 /\u44256 \u50857 \u54805 \u53468 \u48324 \u47196  \u45796 \u47480 \u44032  (\u44032 \u49444  2)
\fs24 \
\
\uc0\u45936 \u51060 \u53552 : 1\u45800 \u44228 \u50752  \u46041 \u51068  \u51088 \u47308  + \u49548 \u46301 /\u44256 \u50857 \u54805 \u53468  \u48320 \u49688 \
\uc0\u54596 \u50836 \u54620  \u48516 \u49437 :\
\
\uc0\u47676 \u51200  "\u44201 \u52264 "\u47484  \u54616 \u45208 \u51032  \u51216 \u49688 \u47196  \u47564 \u46308 \u50612 \u50556  \u54632  \
\'97 \uc0\u50696 : (\u55148 \u47581 \u50668 \u44032  \u51201 \u44537 \u49457  \u51216 \u49688  - \u49892 \u51228 \u50668 \u44032  \u51201 \u44537 \u49457  \u51216 \u49688 ) = "\u50668 \u44032 \u44201 \u52264 \u51648 \u49688 "\u46972 \u45716  \u49352  \u48320 \u49688 \u47484  \u47564 \u46300 \u45716  \u44172  \u54645 \u49900  \u51089 \u50629 \
\uc0\u51060  \u44201 \u52264 \u51648 \u49688 \u47484  \u51333 \u49549 \u48320 \u49688 \u47196  \u46160 \u44256 , \u49548 \u46301 \u49688 \u51456 /\u44256 \u50857 \u54805 \u53468 (\u51221 \u44508 =0, \u48708 \u51221 \u44508 =1)\u47484  \u46021 \u47549 \u48320 \u49688 \u47196  \u54620  \u49440 \u54805 \u54924 \u44480 \u48516 \u49437  \
(\uc0\u46608 \u45716  \u51665 \u45800 \u51060  2\u44060 \u47732  t-\u44160 \u51221 , \u49548 \u46301 \u51012  5\u48516 \u50948  \u46321  3\u44060  \u51060 \u49345  \u48276 \u51452 \u47196  \u45208 \u45572 \u47732  ANOVA)\
\uc0\u53685 \u51228 \u48320 \u49688 \u47196  \u50672 \u47161 , \u54617 \u47141  \u46321 \u51012  \u52628 \u44032 \u54616 \u47732  "\u49548 \u46301 /\u44256 \u50857 \u54805 \u53468 \u51032  \u49692 \u49688 \u54620  \u54952 \u44284 "\u47484  \u45908  \u51221 \u54869 \u55176  \u48380  \u49688  \u51080 \u51020  (\u45796 \u51473 \u54924 \u44480 )\
\
\
\uc0\u51060  \u45800 \u44228 \u44032  \u54924 \u44480 \u48516 \u49437 \u51060  \u44845  \u54596 \u50836 \u54620  \u45800 \u44228 \u50696 \u50836  \
\'97 "\uc0\u44228 \u44553 " \u54532 \u47112 \u51076 \u51032  \u54645 \u49900  \u51613 \u44144 \u51060 \u44592  \u46412 \u47928 \u50640  \u45800 \u49692  \u48516 \u54252  \u52264 \u51060 \u48372 \u45796  \u53685 \u44228 \u51201 \u51004 \u47196  \u50976 \u51032 \u54620  \u52264 \u51060 \u51064 \u51648  \u54869 \u51064 \u54644 \u50556  \u49444 \u46301 \u47141 \u51060  \u49373 \u44200 \u50836 \
\
3\uc0\u45800 \u44228  \'97 \u45432 \u46041 \u51312 \u44148 \u51060  \u44201 \u52264 \u47484  \u49444 \u47749 \u54616 \u45716 \u44032  (\u44032 \u49444  2-1, 2-2)\
\
\uc0\u45936 \u51060 \u53552 : KLIPS (\u46608 \u45716  \u45824 \u52404 \u51088 \u47308 )\
\uc0\u54596 \u50836 \u54620  \u48516 \u49437 :\
\
\uc0\u44032 \u49444  2-1 (\u45432 \u46041 \u49884 \u44036 \'b7\u50629 \u47924 \u51648 \u49884  \u8594  \u54588 \u47196 \'b7\u44060 \u51064 \u49884 \u44036 \u48512 \u51313 ): \u45796 \u51473 \u54924 \u44480 \u48516 \u49437  \'97 \u51333 \u49549 \u48320 \u49688 : \u44060 \u51064 \u49884 \u44036  \u48512 \u51313  \u51064 \u49885 (\u50672 \u49549 \u54805  \u51216 \u49688 ) / \u46021 \u47549 \u48320 \u49688 : \u45432 \u46041 \u49884 \u44036 (\u50672 \u49549 ), \u53748 \u44540 \u54980 \u50629 \u47924 \u51648 \u49884  \u44221 \u54744 (\u48276 \u51452 : 0/1), \u54588 \u47196 \u46020 (\u50672 \u49549  \u46608 \u45716  \u47588 \u44060 \u48320 \u49688 \u47196  \u48324 \u46020  \u48516 \u49437 )\
\uc0\u44032 \u49444  2-2 (\u54788 \u51116 \u50668 \u44032 \u45716  \u49548 \u44537 \u51201 , \u55148 \u47581 \u50668 \u44032 \u45716  \u51201 \u44537 \u51201 ): 1\u45800 \u44228 \u50752  \u46041 \u51068 \u54620  \u48169 \u49885 \u51032  \u44368 \u52264 \u48516 \u49437 /\u48712 \u46020 \u48516 \u49437 \
\uc0\u47564 \u50557  "\u45432 \u46041 \u49884 \u44036  \u8594  \u54588 \u47196  \u8594  \u44060 \u51064 \u49884 \u44036 \u48512 \u51313 "\u52376 \u47100  \u51473 \u44036 \u50640  \u47588 \u44060 \u48320 \u49688 \u44032  \u51080 \u45796 \u44256  \u44032 \u51221 \u54620 \u45796 \u47732  \u47588 \u44060 \u54952 \u44284 \u48516 \u49437 (mediation)\u46020  \u44032 \u45733 \u54616 \u51648 \u47564 , \u51060 \u44148  \u45212 \u51060 \u46020 \u44032  \u45458 \u51004 \u45768  \u52376 \u51020 \u50640 \u45716  \u45800 \u49692  \u45796 \u51473 \u54924 \u44480 \u47196  \u49884 \u51089 \u54616 \u45716  \u44152  \u52628 \u52380 \
\
\
\
4\uc0\u45800 \u44228  \'97 \u44221 \u51228 \u51201  \u50668 \u50976 \u50752 \u51032  \u50672 \u44208  (\u44032 \u49444  3, 3-1)\
\
\uc0\u45936 \u51060 \u53552 : \u52397 \u45380 \u51032  \u49334 \u44284  \u51452 \u44144 \u50640  \u45824 \u54620  \u51064 \u49885 \u51312 \u49324 \
\uc0\u54596 \u50836 \u54620  \u48516 \u49437 :\
\
\uc0\u44032 \u49444  3: \u51452 \u44144 \u48708 \u48512 \u45812  \u48320 \u49688 \u50752  \u50668 \u44032 \u51648 \u52636 /\u50668 \u44032 \u49884 \u44036  \u48320 \u49688  \u44036  \u49345 \u44288 \u48516 \u49437  \u46608 \u45716  \u54924 \u44480 \u48516 \u49437  (\u51452 \u44144 \u48708 \u48512 \u45812 \u51060  \u50672 \u49549 \u54805 \u51060 \u47732  \u54924 \u44480 , \u48276 \u51452 \u54805 \u51060 \u47732  ANOVA)\
\uc0\u44032 \u49444  3-1: "\u51452 \u44144 \u48708  \u52264 \u50529 \u51012  \u50668 \u44032 \u50640  \u50416 \u44192 \u45796 "\u45716  \u51025 \u45813  \u48708 \u50984  \'97 \u48712 \u46020 \u48516 \u49437 \u51004 \u47196  \u52649 \u48516  (\u45800 \u49692  \u51025 \u45813  \u48708 \u50984  \u54869 \u51064 \u51060  \u47785 \u51201 )}